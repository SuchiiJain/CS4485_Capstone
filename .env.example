# Docrot Detector — Webhook Server Environment Variables
# Copy this file to .env and fill in your values.

# REQUIRED: Shared secret for verifying GitHub webhook signatures.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# Must match the secret configured in GitHub → Settings → Webhooks.
DOCROT_WEBHOOK_SECRET=your_webhook_secret_here

# OPTIONAL: GitHub personal access token (PAT) for:
#   - Cloning private repositories
#   - Posting commit statuses back to GitHub
# Scopes needed: repo (or repo:status for public repos)
GITHUB_TOKEN=

# OPTIONAL: Directory where repos are cloned to (default: ./repos)
DOCROT_CLONE_DIR=./repos

# OPTIONAL: Port the webhook server listens on (default: 5000)
DOCROT_PORT=5000

# OPTIONAL: Enable Flask debug mode (default: false)
DOCROT_DEBUG=false
