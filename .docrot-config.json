{
  "language": "python",
  "doc_mappings": [
    {
      "code_glob": "src/*.py",
      "docs": [
        "Readme.md",
        "docs/Architecture.md"
      ]
    }
  ],
  "thresholds": {
    "per_function_substantial": 4,
    "per_doc_cumulative": 8
  },
  "ai": {
    "provider": "groq",
    "model": "llama-3.3-70b-versatile",
    "api_key_env": "GROQ_API_KEY"
  }
}
